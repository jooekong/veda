# Copy to deploy/.env and fill in. Used by docker-compose.yml.
# Never commit a populated .env — secrets stay on the operator's host.

# ── Required (compose refuses to start without these) ──
# 256-bit secret. Generate fresh: openssl rand -hex 32
VEDA_JWT_SECRET=

# Bearer token Prometheus uses to scrape /v1/metrics. Same string also
# goes into deploy/secrets/veda_metrics_token (single newline-free line).
# Generate fresh: openssl rand -hex 24
VEDA_METRICS_TOKEN=

# Embedding provider API key. Veda needs this to embed file content.
VEDA_EMBEDDING_API_KEY=

# ── Optional ──
# LLM API key for summary generation. Leave blank to disable summaries.
VEDA_LLM_API_KEY=

# ── Port mappings (host side) ──
# MYSQL_BIND / MILVUS_BIND default to 127.0.0.1 so storage services aren't
# exposed to the LAN. Set to 0.0.0.0 if you need remote access (and pair
# that with strong MYSQL_PASSWORD).
MYSQL_BIND=127.0.0.1
MYSQL_PORT=3306
MILVUS_BIND=127.0.0.1
MILVUS_PORT=19530
# veda-server / prometheus / grafana stay on 0.0.0.0 by default since
# FUSE / CLI clients on other machines need to reach them.
VEDA_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# MySQL credentials. Cosmetic — only used inside the compose network.
MYSQL_ROOT_PASSWORD=veda-dev-root
MYSQL_DATABASE=veda
MYSQL_USER=veda
MYSQL_PASSWORD=veda-dev

# tracing-subscriber filter. Override for noisier or quieter logs.
RUST_LOG=info,veda=debug
