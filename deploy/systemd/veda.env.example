# Copy to /etc/veda/veda.env and chmod 0640 root:veda. Loaded by both
# veda-server.service and veda-migrate.service via EnvironmentFile=.
# Anything in here overrides the corresponding values from config.toml.

VEDA_JWT_SECRET=
VEDA_METRICS_TOKEN=
VEDA_MYSQL_URL=mysql://veda:veda-dev@127.0.0.1:3306/veda
VEDA_MILVUS_URL=http://127.0.0.1:19530
VEDA_EMBEDDING_API_KEY=
VEDA_LLM_API_KEY=

RUST_LOG=info,veda=debug
